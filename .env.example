# Public base URL used to build QR codes + absolute links.
# Set to your production domain on Vercel (no trailing slash).
# Local dev falls back to window.location.origin if unset.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase — shared serverless store (tables/transactions/menu metadata blob).
# When SUPABASE_URL is set, data is stored in Supabase instead of disk, so it
# syncs across devices on Vercel. Requires a `store(key text primary key,
# value jsonb)` table. Use the service-role key (server-only, never exposed).
# Backend precedence: Supabase -> Vercel KV -> disk.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel KV (or Upstash Redis) — alternative serverless-safe data persistence.
# When KV_REST_API_URL is set (and SUPABASE_URL is not), the app stores
# tables/transactions/menu in KV instead of the local data/store.json file.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob — enables serverless-safe menu file storage. Use a PUBLIC Blob
# store (menus are loaded by diners via URL). When set, uploaded menu files go to
# Blob (public CDN URL) instead of the local public/uploads/ folder.
BLOB_READ_WRITE_TOKEN=

# REQUIRED IN PRODUCTION — the app fails closed (refuses to sign/seed) without
# these. Locally they're optional: the session secret is randomly generated per
# process and the super account seeds from the defaults below.
#
# HMAC key that signs admin session cookies. MUST be a long random string
# (e.g. `openssl rand -base64 32`). Anyone who knows it can forge admin sessions.
SESSION_SECRET=
# The single super account that provisions admins.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Resend — transactional email (trial-admin credentials + contact-sales).
# Real delivery to arbitrary addresses needs a verified sending domain.
RESEND_API_KEY=
RESEND_FROM="QPay <onboarding@resend.dev>"
